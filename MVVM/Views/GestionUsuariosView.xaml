<UserControl x:Class="WPF_PAR.MVVM.Views.GestionUsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{DynamicResource MaterialDesignDefaultFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AccountGroup" Width="32" Height="32" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="Gestión de Usuarios" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <Button HorizontalAlignment="Right" 
                    Command="{Binding CargarUsuariosCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    ToolTip="Recargar Lista">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Actualizar"/>
                </StackPanel>
            </Button>
        </Grid>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding ListaUsuarios}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  IsReadOnly="True"
                  HeadersVisibility="All"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" FontWeight="Bold"/>

                <DataGridTextColumn Header="Nombre Completo" Binding="{Binding NombreCompleto}"/>

                <DataGridTextColumn Header="Rol" Binding="{Binding Rol}"/>

                <DataGridTemplateColumn Header="Estado">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock x:Name="txtEstado" Text="Activo" FontWeight="Bold" Foreground="Green" VerticalAlignment="Center"/>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Activo}" Value="False">
                                    <Setter TargetName="txtEstado" Property="Text" Value="Inactivo"/>
                                    <Setter TargetName="txtEstado" Property="Foreground" Value="Gray"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Acciones">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">

                                <Button ToolTip="Resetear Contraseña" 
                                        Style="{StaticResource MaterialDesignIconButton}" 
                                        Foreground="#FF9800"
                                        Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon Kind="KeyChange" Width="20" Height="20"/>
                                </Button>

                                <Button x:Name="btnToggle" 
                                        ToolTip="Desactivar Usuario" 
                                        Style="{StaticResource MaterialDesignIconButton}" 
                                        Foreground="Red"
                                        Command="{Binding DataContext.AlternarEstadoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon x:Name="iconToggle" Kind="AccountOff" Width="20" Height="20"/>
                                </Button>

                            </StackPanel>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Activo}" Value="False">
                                    <Setter TargetName="btnToggle" Property="ToolTip" Value="Reactivar Usuario"/>
                                    <Setter TargetName="btnToggle" Property="Foreground" Value="Green"/>
                                    <Setter TargetName="iconToggle" Property="Kind" Value="AccountCheck"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>

                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>